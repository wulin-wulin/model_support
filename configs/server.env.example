# Source this file on the server before downloading models or launching vLLM.

export MODEL_SUPPORT_ROOT=/home/dataset-local/data/zos_download/model_support

#
# Strict mode:
# After you finish git pull / code sync, pin HOME into the project so that
# hidden directories like ~/.cache, ~/.config, ~/.nv and ~/.local also stay
# under /home/dataset-local/data/zos_download/model_support for the current shell session.
#
export HOME=/home/dataset-local/data/zos_download/model_support/.home

export HF_HOME=/home/dataset-local/data/zos_download/model_support/.cache/huggingface
export HF_HUB_CACHE=/home/dataset-local/data/zos_download/model_support/.cache/huggingface/hub
export HF_XET_CACHE=/home/dataset-local/data/zos_download/model_support/.cache/huggingface/xet
export HF_ASSETS_CACHE=/home/dataset-local/data/zos_download/model_support/.cache/huggingface/assets
export XDG_CACHE_HOME=/home/dataset-local/data/zos_download/model_support/.cache
export XDG_CONFIG_HOME=/home/dataset-local/data/zos_download/model_support/.config
export XDG_DATA_HOME=/home/dataset-local/data/zos_download/model_support/.local/share
export MODELSCOPE_CACHE=/home/dataset-local/data/zos_download/model_support/.cache/modelscope
export VLLM_CACHE_ROOT=/home/dataset-local/data/zos_download/model_support/.cache/vllm
export VLLM_CONFIG_ROOT=/home/dataset-local/data/zos_download/model_support/.config/vllm
export VLLM_ASSETS_CACHE=/home/dataset-local/data/zos_download/model_support/.cache/vllm/assets
export VLLM_RPC_BASE_PATH=/home/dataset-local/data/zos_download/model_support/.tmp/vllm-rpc
export PIP_CACHE_DIR=/home/dataset-local/data/zos_download/model_support/.cache/pip
export PIP_SRC=/home/dataset-local/data/zos_download/model_support/.cache/pip-src
export UV_CACHE_DIR=/home/dataset-local/data/zos_download/model_support/.cache/uv
export TMPDIR=/home/dataset-local/data/zos_download/model_support/.tmp
export TEMP=/home/dataset-local/data/zos_download/model_support/.tmp
export TMP=/home/dataset-local/data/zos_download/model_support/.tmp
export TORCH_HOME=/home/dataset-local/data/zos_download/model_support/.cache/torch
export TORCH_EXTENSIONS_DIR=/home/dataset-local/data/zos_download/model_support/.cache/torch_extensions
export TORCHINDUCTOR_CACHE_DIR=/home/dataset-local/data/zos_download/model_support/.cache/torchinductor
export TRITON_CACHE_DIR=/home/dataset-local/data/zos_download/model_support/.cache/triton
export TRITON_HOME=/home/dataset-local/data/zos_download/model_support/.cache/triton-home
export CUDA_CACHE_PATH=/home/dataset-local/data/zos_download/model_support/.cache/nv/ComputeCache

# Pin launches to GPUs 0-3 on the shared 8-GPU server.
export CUDA_VISIBLE_DEVICES=0,1,2,3

# Fill these in only when needed.
# export HF_TOKEN=replace_me
# export MODELSCOPE_API_TOKEN=replace_me
# export VLLM_API_KEY=replace_me


export HF_ENDPOINT=https://hf-mirror.com
